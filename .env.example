# Copy to .env and fill in real values. NEVER commit .env to git.

# Frontend origin allowed by CORS
CLIENT_URL=http://localhost:5173

# MongoDB connection WITHOUT a database name (the server appends /DB_NAME)
# Atlas example: mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_URI=

# Database name appended to MONGODB_URI
DB_NAME=premiumbd

# Long random string used to sign JWTs (e.g. `openssl rand -hex 32`)
JWT_SECRET=

# API port
PORT=5005
